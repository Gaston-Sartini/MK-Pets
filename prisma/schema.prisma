// MK-Pets — Prisma Schema
// Auditado por: Database Optimizer Agent
// Índices agregados para todas las FKs y queries frecuentes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase serverless: usar Transaction Mode (puerto 6543)
  directUrl = env("DIRECT_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique  // índice automático por UNIQUE
  emoji     String?
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())

  @@index([order])              // ORDER BY order ASC en nav
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique  // índice automático
  description String?
  images      String[]
  basePrice   Decimal          @db.Decimal(10, 2)
  stock       Int              @default(0)
  isActive    Boolean          @default(true)
  isFeatured  Boolean          @default(false)
  badge       String?
  category    Category         @relation(fields: [categoryId], references: [id])
  categoryId  String
  variants    ProductVariant[]
  orderItems  OrderItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // FK siempre indexada — crítico para JOIN con Category
  @@index([categoryId])

  // Queries más frecuentes de la home y catálogo
  @@index([isActive, isFeatured])           // WHERE isActive=true AND isFeatured=true
  @@index([isActive, categoryId])           // WHERE isActive=true AND categoryId=X
  @@index([isActive, createdAt(sort: Desc)])// ORDER BY createdAt DESC (catálogo)

  // Búsqueda por nombre (ilike) — GIN index para text search
  // Se agrega con migración manual CONCURRENTLY (ver db-indexes.sql)
}

model ProductVariant {
  id        String  @id @default(cuid())
  label     String
  price     Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  // FK indexada — crítico para eager loading de variantes por producto
  @@index([productId])
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique   // índice automático
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  mpPaymentId   String?
  customerName  String
  address       String
  phone         String
  notes         String?
  items         OrderItem[]
  total         Decimal       @db.Decimal(10, 2)
  canModifyUntil DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Panel admin: filtrar por estado y ordenar por fecha
  @@index([status, createdAt(sort: Desc)])

  // Webhook de MP busca por mpPaymentId
  @@index([mpPaymentId])

  // Query de modificación: buscar por orderNumber ya tiene índice (UNIQUE)
}

model OrderItem {
  id           String  @id @default(cuid())
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  product      Product @relation(fields: [productId], references: [id])
  productId    String
  variantLabel String?
  quantity     Int
  unitPrice    Decimal @db.Decimal(10, 2)

  // Ambas FKs indexadas — crítico para JOIN en detalle de pedido
  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  MODIFIED
}

enum PaymentMethod {
  MERCADOPAGO
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}
